# App
NEXT_PUBLIC_APP_NAME=Booklog
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Postgres connection string.
# Local (Docker):   postgres://booklog:booklog@localhost:5432/booklog
# Production:        use your hosted pooled connection string, e.g. Neon/Supabase/Vercel Postgres
#                    (append ?sslmode=require for hosted databases)
DATABASE_URL=postgres://booklog:booklog@localhost:5432/booklog

# AI mode: none (no AI calls) | bifrost (OpenAI-compatible gateway, server-side only)
AI_PROVIDER=none
BIFROST_BASE_URL=https://gateway-buildathon.ltl.sh/v1
BIFROST_CHAT_COMPLETIONS_URL=https://gateway-buildathon.ltl.sh/v1/chat/completions
BIFROST_API_KEY=replace_with_env_secret_never_commit
BIFROST_MODEL=replace_with_model_name_from_org
